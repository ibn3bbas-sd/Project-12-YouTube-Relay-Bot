# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_ID=your_telegram_chat_id_here

# ─── YouTube Source Channel ───────────────────────────────────────────────────
SOURCE_CHANNEL_ID=UC8semOV-MqT3enT4M0mS1ow

# ─── YouTube Target Channel ───────────────────────────────────────────────────
TARGET_CHANNEL_ID=UCCKQxDfs0eIVsLmnc4JVtpQ
# Path to your OAuth2 client_secret JSON downloaded from Google Cloud Console
YOUTUBE_CLIENT_SECRET_FILE=config/client_secret.json
# Auto-generated after first auth — do not commit
YOUTUBE_TOKEN_FILE=config/token.json

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Times in 24h format, Asia/Riyadh timezone (UTC+3)
SCHEDULE_MORNING=06:00
SCHEDULE_EVENING=18:00
TIMEZONE=Asia/Riyadh

# ─── Downloads ────────────────────────────────────────────────────────────────
DOWNLOAD_DIR=downloads
MAX_VIDEO_AGE_DAYS=7
VIDEO_QUALITY=best[height<=1080]

# ─── Optional: Gemini AI (free tier) ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_ENABLED=false
